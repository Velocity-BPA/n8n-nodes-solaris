{
  "name": "n8n-nodes-solaris",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Solaris embedded banking platform (Banking-as-a-Service) providing 25 resources and 200+ operations for person/business management, accounts, SEPA transfers, card issuing, compliance, and PSD2/SCA authentication.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-solaris.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-solaris#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-solaris/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "solaris",
    "solarisbank",
    "banking",
    "banking-as-a-service",
    "baas",
    "embedded-banking",
    "sepa",
    "sepa-instant",
    "card-issuing",
    "psd2",
    "sca",
    "kyc",
    "video-ident",
    "german-banking",
    "fintech",
    "payments",
    "direct-debit",
    "overdraft",
    "compliance"
  ],
  "main": "dist/nodes/Solaris/Solaris.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SolarisApi.credentials.js",
      "dist/credentials/SolarisOAuth.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Solaris/Solaris.node.js",
      "dist/nodes/Solaris/SolarisTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/node-forge": "^1.3.11",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.22.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "node-forge": "^1.3.1"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
